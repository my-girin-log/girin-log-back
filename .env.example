# 로컬 실제 구동 검증용 환경변수 템플릿.
# 복사해서 .env.local 로 만들고 값을 채운다(.env.local 은 gitignore — 커밋 금지).
#   cp .env.example .env.local

# --- DB (docker postgres 기본값과 일치) ---
# docker run -d --name girinlog-pg -e POSTGRES_DB=girinlog -e POSTGRES_USER=girinlog \
#   -e POSTGRES_PASSWORD=girinlog -p 5432:5432 postgres:16
export DB_URL=jdbc:postgresql://localhost:5432/girinlog
export DB_USERNAME=girinlog
export DB_PASSWORD=girinlog
# 로컬 검증 전용: 마이그레이션 도구가 없으므로 테이블 자동 생성. (운영 금지)
export JPA_DDL_AUTO=update

# --- 자체 JWT (32자 이상 랜덤. 예: openssl rand -base64 48) ---
export GIRINLOG_JWT_SECRET=

# --- GitHub OAuth App ---
# https://github.com/settings/developers → New OAuth App
#   Authorization callback URL: http://localhost:8080/api/auth/github/callback
export GITHUB_CLIENT_ID=
export GITHUB_CLIENT_SECRET=

# --- Gemini ---
export GEMINI_API_KEY=
# 키에 따라 gemini-2.0-flash 무료 티어가 막혀 있으면(429) 비-thinking 계열로 교체.
# (thinking 모델은 작은 maxOutputTokens 예산에서 JSON 출력이 잘릴 수 있음)
# export GEMINI_MODEL=gemini-flash-lite-latest
# export GEMINI_TIMEOUT=PT90S
